# ═══════════════════════════════════════════
# Smart Wallet MCP Server — Environment Vars
# ═══════════════════════════════════════════

# Supabase (optional — uses in-memory store if not set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# HTTP API port (for frontend chat + webhooks)
API_PORT=3001

# ── Telegram Bot ──────────────────────────
# Create bot via @BotFather on Telegram
# Optional: leave empty to disable Telegram channel
TELEGRAM_BOT_TOKEN=

# ── WhatsApp via Twilio ───────────────────
# Sign up at twilio.com, enable WhatsApp sandbox
# Optional: leave empty to disable WhatsApp channel
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
