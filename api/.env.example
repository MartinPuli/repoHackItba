# API
PORT=3000

# Supabase (dashboard: Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=

# NUNCA USAR EN EL FRONTEND / ni en NEXT_PUBLIC_*.
# Privilegios elevados y bypass de RLS; solo en este servidor.
SUPABASE_SERVICE_ROLE_KEY=

# EVM RPC (p. ej. BSC Testnet) para ethers u otros usos on-chain
RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# WebAuthn: RP_ID = dominio sin protocolo ni puerto. FRONTEND_ORIGIN = URL completa del frontend.
WEBAUTHN_RP_ID=localhost
FRONTEND_ORIGIN=http://localhost:3000